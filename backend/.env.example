# Amrutha Chicken Center Backend Environment Variables Configuration Example
# Copy this file to .env and configure the variables accordingly for deployment.

# Spring Active Profile (dev or prod)
SPRING_PROFILES_ACTIVE=prod

# Server Port Configuration
PORT=8080

# MySQL Database Configuration
DATABASE_URL=jdbc:mysql://localhost:3306/amrutha_chicken_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=root
DATABASE_PASSWORD=your_secure_password_here

# JWT Security Secrets (Must be at least 256 bits, e.g., 64 hex characters)
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION_MS=86400000

# Cloudinary Storage Configuration (Optional, falls back to local storage if not provided)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Production CORS Allowed Origins (Comma-separated list of allowed domains, or * to permit all)
ALLOWED_ORIGINS=https://amrutha-chicken-center.onrender.com

# HikariCP Connection Pooling Tuning (Optional)
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_CONNECTION_TIMEOUT=30000
